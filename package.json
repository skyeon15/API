{
  "name": "pds-monorepo",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start:api": "npm run dev --filter=api",
    "start:web": "npm run dev --filter=web",
    "migration:run": "npm run migration:run --workspace=apps/api"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.4.2"
  }
}
