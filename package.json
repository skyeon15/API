{
  "name": "pds-monorepo",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "doppler run -- turbo build",
    "dev": "doppler run -- turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start": "doppler run -- sh -c 'turbo run start:prod --filter=api & turbo run start --filter=web'",
    "start:api": "doppler run -- npm run start:prod --workspace=apps/api",
    "start:web": "doppler run -- npm run start --workspace=apps/web",
    "migration:run": "doppler run -- npm run migration:run --workspace=apps/api"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.4.2"
  }
}
