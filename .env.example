# Database Configuration
API_DB_HOST=localhost
API_DB_PORT=5432
API_DB_NAME=pds_api
API_DB_USER=admin
API_DB_PASSWORD=devpass

# Redis Configuration
API_REDIS_HOST=localhost
API_REDIS_PORT=6379

# Server Configuration
API_PORT=10151
API_URL=http://localhost:10151
API_WEB_URL=http://localhost:10150
API_ALLOWED_ORIGINS=https://*.bbforest.net,https://*.riri.li,https://*.hapbbi.com

# Authentication
API_JWT_SECRET=your_jwt_secret_here

# Social Login (OAuth2)
API_KAKAO_CLIENT_ID=your_kakao_client_id
API_KAKAO_CLIENT_SECRET=your_kakao_client_secret
API_NAVER_CLIENT_ID=your_naver_client_id
API_NAVER_CLIENT_SECRET=your_naver_client_secret
API_GOOGLE_CLIENT_ID=your_google_client_id
API_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Aligo Alimtalk API
API_ALIGO_API_KEY=your_aligo_key
API_ALIGO_USER_ID=your_aligo_user_id
