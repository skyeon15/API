# --- Server Configuration ---
API_PORT=10151
API_ALLOWED_ORIGINS=http://localhost:10150,http://localhost:10151,https://*.bbforest.net,https://*.riri.li,https://*.hapbbi.com

# --- Database Configuration (PostgreSQL 18) ---
API_DB_HOST=db
API_DB_PORT=5432
API_DB_NAME=pds_api
API_DB_USER=pds_user
API_DB_PASSWORD=pds_password

# --- Redis Configuration ---
API_REDIS_HOST=redis
API_REDIS_PORT=6379

# --- Authentication ---
API_JWT_SECRET=your_jwt_secret_key_here

# --- External APIs (Aligo Alimtalk) ---
API_ALIGO_API_KEY=your_aligo_api_key
API_ALIGO_USER_ID=your_aligo_user_id
API_ALIGO_FAILOVER=Y   # Y: 알림톡 실패 시 SMS 대체 발송, N: 대체 발송 안 함

# --- External APIs (Payapp) ---
API_PAYAPP_USERID=your_payapp_userid
API_PAYAPP_LINKKEY=your_payapp_linkkey
API_PAYAPP_RESELLERID=your_payapp_resellerid
